# Path to your Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Google Drive folder IDs
INBOX_FOLDER_ID=your_inbox_folder_id_here
ARCHIVE_FOLDER_ID=your_archive_folder_id_here

# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for transcription and synthesis (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Supabase PostgreSQL connection string
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres
